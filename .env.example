VITE_UNBLOCK_PORT=3100
VITE_UNBLOCK_SOURCES=kuwo kugou pyncmd bilibili
ENABLE_FLAC=true
ENABLE_LOCAL_VIP=cvip
# GitHub Pages 场景建议配置远程 UNM 服务
# VITE_REMOTE_UNM_BASE=https://your-unm.example.com/unm-api
# GitHub Pages 为 https 页面时，http 音频需通过 https 流代理
# VITE_STREAM_PROXY_BASE=https://your-stream-proxy.workers.dev
# 可选：若启用 qq/migu/joox 音源，请配置对应 Cookie
# QQ_COOKIE=
# MIGU_COOKIE=
# JOOX_COOKIE=
